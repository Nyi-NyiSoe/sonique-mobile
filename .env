# Base Endpoint
endpoint = "http://192.168.1.37:3000"

# Auth URLs
LOGIN_URL = "${endpoint}/auth/login"
REGISTER_URL = "${endpoint}/auth/register"

# Song URLs
GET_ALL_SONGS_URL = "${endpoint}/songs/all?limit=10"
GET_SONG_DETAIL_URL = "${endpoint}/songs/"
GET_SONG_GENRES_URL = "${endpoint}/songs/genres/all"
UPLOAD_SONG_GENRE_URL = "${endpoint}/songs/genres"
UPLOAD_SONG_URL = "${endpoint}/songs/upload"
LIKE_SONG_URL = "${endpoint}/songs/likes"
UNLIKE_SONG_URL = "${endpoint}/songs/likes"
LOAD_LIKED_SONGS_URL = "${endpoint}/songs/likes"

# User URLs
GET_USER_DETAIL_URL = "${endpoint}/user/"
UPDATE_USER_DETAIL_URL = "${endpoint}/user/"

# Album URLs
GET_ALL_ALBUMS_URL = "${endpoint}/album"
GET_ALBUM_DETAIL_URL = "${endpoint}/album/detail/"
GET_ALBUM_ARTISTID_URL = "${endpoint}/album/"
CREATE_ALBUM_URL = "${endpoint}/album/create"
ADD_SONGS_TO_ALBUM_URL = "${endpoint}/album/add-song"
REMOVE_SONGS_FROM_ALBUM_URL = "${endpoint}/album/remove-song"

# Artist URLs
GET_ALL_ARTISTS_URL = "${endpoint}/user"

#Play list URLs
GET_USER_PLAYLISTS_URL = "${endpoint}/playlist/"
CREATE_PLAYLIST_URL = "${endpoint}/playlist/create"
DELETE_PLAYLIST_URL = "${endpoint}/playlist/delete"
GET_PLAYLIST_DETAIL_URL = "${endpoint}/playlist/details/"
ADD_SONGS_TO_PLAYLIST_URL = "${endpoint}/playlist/add-song"
REMOVE_SONGS_FROM_PLAYLIST_URL = "${endpoint}/playlist/remove-song"
